generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

enum Level {
  BRONCE
  PLATA
  ORO
}

model User {
  id          String  @id @default(uuid())
  firebaseUid String  @unique
  email       String? @unique
  phoneNumber String? @unique
  role        Role    @default(CLIENT)
  firstName   String
  lastName    String?
  avatarUrl   String?

  // Cliente-specific fields
  level           Level     @default(BRONCE)
  lastPaymentDate DateTime?
  creditLimit     Float     @default(0)

  // Relaciones
  transactions     Transaction[]
  deliveryRequests DeliveryRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id         String     @id @default(uuid())
  name       String     @unique // e.g. "Dama", "Caballero", "Unisex"
  categories Category[]
  createdAt  DateTime   @default(now())
}

model Category {
  id           String     @id @default(uuid())
  name         String // e.g. "Zapatos", "Sudaderas", "Perfumes"
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  products     Product[]
  createdAt    DateTime   @default(now())

  @@unique([name, departmentId])
}

model Product {
  id          String   @id @default(uuid())
  barcode     String   @unique
  name        String
  description String?
  color       String?
  size        String?
  sizeUnit    String?
  brand       String?
  stock       Int      @default(0)
  price       Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  imageUrl    String?

  transactionItems TransactionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionType {
  CONTADO
  CREDITO_SEMANAL
  APARTADO
  PRESTAMO
}

enum TransactionStatus {
  PENDING_APPROVAL // Waiting for client to accept in the app
  ACTIVE // Accepted and ongoing (or Layaway/Loan active)
  COMPLETED // Paid in full or Loan returned
  CANCELLED // Layaway expired or Client rejected
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type        TransactionType
  status      TransactionStatus @default(PENDING_APPROVAL)
  totalAmount Float             @default(0)

  // Para apartados
  expiresAt DateTime? // Un mes despues de crearse
  extended  Boolean   @default(false) // Si ya se extendio la semana extra

  items    TransactionItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int
  priceAtTime   Float
}

model Payment {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amount        Float
  paymentDate   DateTime    @default(now())
  method        String // Efectivo, Tarjeta, etc
}

enum DeliveryStatus {
  PENDING
  ACCEPTED
  REJECTED
  DELIVERED
}

model DeliveryRequest {
  id      String         @id @default(uuid())
  userId  String
  user    User           @relation(fields: [userId], references: [id])
  address String
  status  DeliveryStatus @default(PENDING)
  notes   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
