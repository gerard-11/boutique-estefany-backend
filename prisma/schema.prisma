generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

enum Level {
  BRONCE
  PLATA
  ORO
}

model User {
  id          String  @id @default(uuid())
  firebaseUid String  @unique
  email       String? @unique
  phoneNumber String? @unique
  role        Role    @default(CLIENT)
  firstName   String
  lastName    String?
  avatarUrl   String?

  // Cliente-specific fields
  level           Level     @default(BRONCE)
  lastPaymentDate DateTime?
  creditLimit     Float     @default(0)
  balance         Float     @default(0) // Saldo en monedero

  // Relaciones
  transactions     Transaction[]
  deliveryRequests DeliveryRequest[]
  walletMovements  WalletMovement[]
  wishlistItems    Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

enum WalletMovementType {
  DEPOSIT
  WITHDRAWAL
  RETURN_CREDIT
  PURCHASE_PAYMENT
}

model WalletMovement {
  id        String             @id @default(uuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  amount    Float // Positivo para entradas, Negativo para salidas
  type      WalletMovementType
  reason    String?
  createdAt DateTime           @default(now())
}

model Department {
  id         String     @id @default(uuid())
  name       String     @unique // e.g. "Dama", "Caballero", "Unisex"
  categories Category[]
  createdAt  DateTime   @default(now())
}

model Category {
  id           String     @id @default(uuid())
  name         String // e.g. "Zapatos", "Sudaderas", "Perfumes"
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  products     Product[]
  createdAt    DateTime   @default(now())

  @@unique([name, departmentId])
}

model Product {
  id          String   @id @default(uuid())
  barcode     String   @unique
  name        String
  description String?
  color       String?
  size        String?
  sizeUnit    String?
  brand       String?
  stock       Int      @default(0)
  price       Float    // Precio de venta actual
  cost        Float    @default(0) // Costo de compra actual
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  imageUrl    String?

  transactionItems   TransactionItem[]
  inventoryMovements InventoryMovement[] // Relación con bitácora
  deliveryRequestItems DeliveryRequestItem[]
  wishlistItems      Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MovementType {
  VENTA
  DEVOLUCION_CLIENTE
  DEVOLUCION_PROVEEDOR
  MERMA
  AJUSTE_MANUAL
}

model InventoryMovement {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  quantity    Int // Positivo para entradas, Negativo para salidas
  type        MovementType
  costAtTime  Float        @default(0) // Costo de compra en el momento del movimiento
  priceAtTime Float        @default(0) // Precio de venta en el momento del movimiento
  reason      String? // Nota opcional del Admin
  createdAt   DateTime     @default(now())
}

enum TransactionType {
  CONTADO
  CREDITO_SEMANAL
  APARTADO
  PRESTAMO
}

enum TransactionStatus {
  PENDING_APPROVAL // Waiting for client to accept in the app
  ACTIVE // Accepted and ongoing (or Layaway/Loan active)
  COMPLETED // Paid in full or Loan returned
  CANCELLED // Layaway expired or Client rejected
  RETURN_REQUESTED // Client wants to return (New)
  RETURNED // Admin confirmed return (New)
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  type          TransactionType
  status          TransactionStatus @default(PENDING_APPROVAL)
  originalAmount  Float             @default(0)
  discountPercentage Float          @default(0)
  totalAmount     Float             @default(0)
  weeklyPayment   Float?

  // Para apartados
  expiresAt DateTime? // Un mes despues de crearse
  extended  Boolean   @default(false) // Si ya se extendio la semana extra

  items    TransactionItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionItem {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int
  priceAtTime   Float
  costAtTime    Float       @default(0) // Costo de compra al momento de la venta
}

model Payment {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  amount        Float
  paymentDate   DateTime    @default(now())
  method        String // Efectivo, Tarjeta, etc
}

enum DeliveryStatus {
  PENDING
  ACCEPTED
  REJECTED
  DELIVERED
}

model DeliveryRequest {
  id      String         @id @default(uuid())
  userId  String
  user    User           @relation(fields: [userId], references: [id])
  address String
  status  DeliveryStatus @default(PENDING)
  notes   String?

  items   DeliveryRequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliveryRequestItem {
  id                String          @id @default(uuid())
  deliveryRequestId String
  deliveryRequest   DeliveryRequest @relation(fields: [deliveryRequestId], references: [id])
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  quantity          Int             @default(1)
}
